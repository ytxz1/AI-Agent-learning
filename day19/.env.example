# Day19 RAG 项目配置示例
# 复制为 .env 后填写自己的真实配置。

# 聊天模型配置：可以使用 DeepSeek 或 OpenAI 兼容服务。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# Embedding 模型配置：建议和聊天模型分开配置。
# 如果你使用 OpenAI 官方 embedding，可以这样写：
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=200
CHUNK_OVERLAP=50
TOP_K=3
TEMPERATURE=0.7
