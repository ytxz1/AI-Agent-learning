# Day24 部署上线项目配置示例
# 复制为 .env 后，可以根据本地或服务器环境修改。

APP_NAME=Day24 部署上线 API
APP_VERSION=1.0.0
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000
DOCS_URL=/docs
REDOC_URL=/redoc

# 部署环境标识：local / docker / production
ENVIRONMENT=local

# 健康检查时展示的服务名称
SERVICE_NAME=day24-deploy-api

# 默认不通过 python main.py 直接启动服务，避免误运行时一直占用终端。
RUN_SERVER=0
