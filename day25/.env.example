# Day25 Streamlit 前端界面配置示例
# 复制为 .env 后可以修改。

APP_TITLE=Day25 AI Agent Web 界面
APP_SUBTITLE=把后端 API 变成用户可以直接操作的页面

# 如果你已经启动了 Day23 或 Day24 的后端 API，可以修改这里。
# Day23 推荐接口：http://127.0.0.1:8000/api/agent/chat
AGENT_API_URL=http://127.0.0.1:8000/api/agent/chat

# local 表示本地模拟回答；api 表示调用 AGENT_API_URL。
DEFAULT_MODE=local

# 页面主题色。
PRIMARY_COLOR=#0F766E
ACCENT_COLOR=#F59E0B
