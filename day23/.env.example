# Day23 集成项目 API 配置示例
# 复制为 .env 后，可以按自己的环境修改。

APP_NAME=Day23 Agent API 集成项目
APP_VERSION=1.0.0
API_PREFIX=/api
HOST=127.0.0.1
PORT=8000
DOCS_URL=/docs
REDOC_URL=/redoc

# 如果你有可用的 OpenAI API Key，可以填在 .env 里。
# 没有 Key 时，本项目会自动使用本地模拟 Agent，确保代码仍然可以运行。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 跨域配置：开发阶段可以允许本地前端地址。
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 默认不通过 python main.py 直接启动服务，避免误运行时一直占用终端。
RUN_SERVER=0
